collection(dynamic/runtime values):
  String:
    syntex: 
      String::new()

  Vec(Storing Lists of Values ):
    syntex: 
      let v: Vec<i32> = Vec::new();
      let v = vec![1, 2, 3];
    access:
      &v[<index>](panic if no value in index)
      v.get(<index>)(return None if no value in index)
      
  HashMap(just like obj/key val pair):
    syntex: 
      use std::collections::HashMap;  
      let mut scores = HashMap::new();
      scores.insert(String::from("Blue"), 10);
      scores.insert(String::from("Yellow"), 50);

    access:
      let team_name = String::from("Blue");
      let score = scores.get(&team_name).copied().unwrap_or(0);